# ── Fan Control Configuration ──────────────────────────────────────
#
# Copy this file to fanctl.toml in the project root (where main.py
# lives).  It will be found automatically — no env vars needed.
#
#     cp fancontrol/fanctl.toml.example fanctl.toml
#
# Search order (first found wins):
#   1. FAN_CONFIG env var pointing to a specific path.
#   2. fanctl.toml in the project root (alongside main.py).
#   3. fanctl.toml in the current working directory.
#
# Everything here can be overridden via environment variables — see
# the "Environment:" notes on each field below.
#
# ── Board Reference ────────────────────────────────────────────────
#
# | Board                     | Chip          | Line | Tool              | active_low |
# |---------------------------|---------------|------|-------------------|------------|
# | Radxa Zero 3W (Amlogic A311D2) | gpiochip3 | 20   | gpioset           | false      |
# | Raspberry Pi 2/3/4        | gpiochip0     | 18   | raspi-gpio        | false      |
# | Raspberry Pi 5            | gpiochip0     | 18   | pinctrl           | false      |
# | Orange Pi 5 (RK3588)      | gpiochip0     | 88   | gpioset           | false      |
# | Orange Pi Zero 2          | gpiochip0     | 68   | gpioset           | false      |
# | Jetson Nano (Tegra)       | gpiochip0     | 396  | gpioset           | false      |
# | Jetson Orin               | gpiochip0     | 402  | gpioset           | false      |
# | ASUS Tinker Board         | gpiochip0     | 148  | gpioset           | false      |
# | Odroid N2+                | gpiochip0     | 492  | gpioset           | false      |
# | Odroid C4                 | gpiochip0     | 498  | gpioset           | false      |
# | Banana Pi M5              | gpiochip0     | 142  | gpioset           | false      |
# | Rock Pi 4                 | gpiochip0     | 148  | gpioset           | false      |
# | BeagleBone Black          | gpiochip0     | 60   | gpioset           | false      |
# | Generic x86 (GPIO)        | gpiochip1     | *    | gpioset           | false      |
# | macOS / no GPIO           | —             | —    | (not applicable)  | —         |
#
# *  On x86 boards with Super I/O GPIO, the chip number varies.
#    Run `ls /dev/gpiochip*` and `gpioinfo` to discover.
#
# ── Quick Test ─────────────────────────────────────────────────────
#
# Find your fan header by testing the GPIO line manually:
#
#     # Radxa Zero 3W — gpiochip3 line 20 (physical pin 7)
#     sudo gpioset -c gpiochip3 20=1   # fan ON
#     sudo gpioset -c gpiochip3 20=0   # fan OFF
#
#     # Raspberry Pi — BCM GPIO 18 (physical pin 12)
#     sudo gpioset -c gpiochip0 18=1   # fan ON
#     sudo gpioset -c gpiochip0 18=0   # fan OFF
#
# Then set a low temperature threshold to verify the software control:
#
#     export FAN_TEMP_THRESHOLD=30     # °C — triggers immediately on any running CPU
#     python -c "
#     from fancontrol.fanctl import FanController
#     ctrl = FanController()
#     ctrl.auto()  # should turn fan on if CPU > 30°C
#     input('Press Enter to stop fan...')
#     ctrl.off()
#     "
#
# ── Configuration ──────────────────────────────────────────────────

[fan]

# GPIO chip name (run `ls /dev/gpiochip*` to list).
# Environment: FAN_GPIO_CHIP
chip = "gpiochip0"

# GPIO line (offset within the chip).
# For Raspberry Pi, this is the BCM GPIO number.
# Environment: FAN_GPIO_LINE
line = 20

# Set to true if your fan circuit is active-low
# (GPIO=0 → fan ON, GPIO=1 → fan OFF).
# Environment: FAN_ACTIVE_LOW
active_low = false

# Force a specific backend.  Options:
#   libgpiod   gpioset   pinctrl   raspi-gpio   sysfs
# Leave unset or empty for auto-detection.
# Environment: FAN_BACKEND
# backend = "gpioset"

# CPU temperature threshold (°C) for automatic fan control.
# When the CPU exceeds this, the fan turns on.
# Set to 0 to disable thermal auto-control.
# For testing, set to 30 — most CPUs will trigger immediately.
# Environment: FAN_TEMP_THRESHOLD
temp_threshold = 30.0

# Temperature hysteresis (°C) — prevents rapid on/off cycling.
# Once the fan is on, it stays on until the CPU cools to
# (temp_threshold - temp_hysteresis).
# Environment: FAN_TEMP_HYSTERESIS
temp_hysteresis = 5.0
